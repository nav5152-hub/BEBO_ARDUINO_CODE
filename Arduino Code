// ---------- Obstacle Avoidance State Machine ----------
// Eight-step sequence to navigate around an obstacle
enum AvoidState {
  AVOID_NONE = 0,  // No avoidance in progress
  AVOID_TURN_1,    // First turn away from obstacle
  AVOID_SHIFT_1,   // First lateral shift
  AVOID_TURN_2,    // Second turn to align with obstacle
  AVOID_PASS,      // Drive past the obstacle
  AVOID_TURN_3,    // Third turn to re-align with original path
  AVOID_SHIFT_2,   // Second lateral shift back
  AVOID_TURN_4     // Fourth turn to restore original heading
};
AvoidState avoidState = AVOID_NONE;
